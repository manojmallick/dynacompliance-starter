# DynaCompliance — environment template. Copy to .env and fill in. NEVER commit .env.

# --- Gemini (REQUIRED) ---
# Option A (simplest, used on Vercel): Gemini Developer API key.
GEMINI_API_KEY=
# Option B (Vertex AI, native on Cloud Run): leave GEMINI_API_KEY blank and set these.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=europe-west1
GOOGLE_GENAI_USE_VERTEXAI=true
# Model id — verify this id is available to your key/project before going live.
GEMINI_MODEL=gemini-3

# --- Dynatrace (partner) ---
# REST API v2 path (default read path + the approval-gated write-back):
DT_ENV_URL=https://your-env.live.dynatrace.com
DT_API_TOKEN=dt0c01.XXXXXXXX.XXXXXXXXXXXXXXXX

# MCP path — set DT_USE_MCP=true to route reads through the real Dynatrace MCP server
# (@dynatrace-oss/dynatrace-mcp-server), called at runtime by src/dynatrace-mcp.js.
# NOTE the MCP server uses the *Platform* URL (apps.dynatrace.com, not classic .live.)
# and a Platform token — distinct from the REST Api-Token above.
DT_USE_MCP=false
DT_ENVIRONMENT=https://abc12345.apps.dynatrace.com
DT_PLATFORM_TOKEN=dt0s16.XXXXXXXX.XXXXXXXXXXXXXXXX

# --- Audit ledger persistence (Neon Postgres) ---
# When set, the approval ledger persists across serverless invocations.
# Leave blank for the in-memory demo fallback.
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# --- Cross-app handoff (optional) ---
INCIDENTIQ_URL=

# --- App ---
PORT=8080
NODE_ENV=development

# --- Demo mode: MOCK=true runs the full UI + ApprovalBar flow with canned data
#     and NO credentials (great for rehearsing the ~3-min demo). ---
# MOCK=true
